#: includes/class.upgrader.php:209
msgid "We detected and resolved an issue with certain markers containing malicious code. The system has automatically cleaned up affected content, however, some marker fields have been removed. If you would like to know more, please contact support."
msgstr "Chúng tôi đã phát hiện và giải quyết sự cố với một số điểm đánh dấu chứa mã độc hại. Hệ thống đã tự động dọn dẹp nội dung bị ảnh hưởng, tuy nhiên, một số trường điểm đánh dấu đã bị xóa. Nếu bạn muốn biết thêm thông tin, vui lòng liên hệ hỗ trợ."

#: html/atlas-novus/settings-page.html.php:2715
#: html/settings-page.html.php:1603
msgid "Add/remove performance indexes from the database tables that may improve query times. Only do this if suggested by our support team"
msgstr "Thêm/xóa các chỉ số hiệu suất từ các bảng cơ sở dữ liệu có thể cải thiện thời gian truy vấn. Chỉ thực hiện điều này nếu được nhóm hỗ trợ của chúng tôi đề xuất"

#: html/atlas-novus/settings-page.html.php:2707
msgid "Performance"
msgstr "Hiệu suất"

#: html/atlas-novus/settings-page.html.php:2099
msgid "Defer all mapping script assets loaded on your site"
msgstr "Hoãn tải tất cả tài nguyên script bản đồ được tải trên trang web của bạn"

#: html/atlas-novus/settings-page.html.php:2087
msgid "Defer Loading"
msgstr "Hoãn tải"

#: html/atlas-novus/settings-page.html.php:2113 html/settings-page.html.php:518
msgid "Aligns API loading with best-practice from Google. Considered beta for now, will become default later"
msgstr "Căn chỉnh việc tải API với thực tiễn tốt nhất từ Google. Hiện đang được xem là phiên bản beta, sẽ trở thành mặc định sau này"

#: html/atlas-novus/settings-page.html.php:2108 html/settings-page.html.php:514
