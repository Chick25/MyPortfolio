msgid "By opting in, your site URL will be shared with our servers in order to create an API key."
msgstr "Bằng cách chọn, URL trang web của bạn sẽ được chia sẻ với máy chủ của chúng tôi để tạo API Key."

#: html/atlas-novus/installer-page.html.php:816
#: html/installer-page.html.php:266
msgid "This key can be used to explore our tools, but will need to be replaced with your own API key later."
msgstr "Key này có thể được sử dụng để khám phá các công cụ của chúng tôi, nhưng sẽ cần được thay thế bằng API Key của riêng bạn sau này."

#: html/atlas-novus/installer-page.html.php:813
#: html/installer-page.html.php:263
